# ── App ───────────────────────────────────────────────────────
APP_ENV=development          # development | production

# ── PostgreSQL ────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=scraper_db
PGUSER=postgres
PGPASSWORD=your_strong_password_here
PGSSLMODE=prefer
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Proxy ─────────────────────────────────────────────────────
PROXY_ENABLED=true
# Option A — rotating gateway (Bright Data, Oxylabs, etc.)
PROXY_GATEWAY_URL=http://proxy-provider-host:port
PROXY_USERNAME=your_proxy_user
PROXY_PASSWORD=your_proxy_password
# Option B — static list (comma-separated)
PROXY_STATIC_LIST=http://user:pass@ip1:port,http://user:pass@ip2:port
# Preferred country (optional)
PROXY_COUNTRY=US
# Rotate IP every N requests
PROXY_ROTATE_EVERY=10

# ── Scraper ───────────────────────────────────────────────────
SCRAPER_WORKERS=4
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=4.0
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF=2.0
SCRAPER_TIMEOUT=30
SCRAPER_HEADLESS=true
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_RATE_LIMIT_RPM=20

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_MASK_SECRETS=true
